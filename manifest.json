{
  "manifest_version": 3,
  "name": "IanChromeTab - 网页标签高级管理",
  "version": "1.0",
  "description": "智能按域名对标签页进行两级分组管理，并提供自定义极简中控台。",
  "permissions": [
    "tabs",
    "tabGroups",
    "storage",
    "favicon",
    "alarms",
    "system.memory"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "chrome_url_overrides": {
    "newtab": "dashboard.html"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "打开 IanChromeTab 中控台",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
